{
  "name": "inoslides-theme",
  "private": true,
  "scripts": {
    "dev": "slidev",
    "build": "slidev build"
  },
  "keywords": [
    "slidev",
    "slidev-theme"
  ],
  "engines": {
    "slidev": ">=52.15.2"
  },
  "slidev": {
    "colorSchema": "light",
    "defaults": {
      "transition": "fade",
      "mdc": true,
      "fonts": {
        "sans": [
          "Poppins",
          "Noto Sans JP"
        ],
        "serif": "Roboto Slab",
        "mono": "Fira Code"
      }
    }
  },
  "dependencies": {
    "@slidev/client": "^52.15.2",
    "codemirror-theme-vars": "^0.1.2",
    "prism-theme-vars": "^0.2.4"
  },
  "devDependencies": {
    "@slidev/cli": "52.15.2"
  }
}